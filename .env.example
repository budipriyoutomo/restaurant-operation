# Copy this file to .env and fill in your values
# psycopg3 dialect — note the "+psycopg" in the scheme
DATABASE_URL=postgresql+psycopg://restaurantops:password@localhost:5432/restaurantops

# Separate test DB so tests never touch production data
TEST_DATABASE_URL=postgresql+psycopg://restaurantops:password@localhost:5432/restaurantops_test

CORS_ORIGINS=http://localhost:3000

# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# development | staging | production
ENVIRONMENT=development

# Rate limiting (requests per IP per time window)
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_WRITE=20/minute
